---
import { visibleFacets } from '../data/facets';
import siteData from '../data/site.json';
import { getCollection } from 'astro:content';
import sonJson    from '../data/son.json';
import regieJson  from '../data/regie.json';
import coursJson  from '../data/cours.json';
import blogJson   from '../data/blog.json';
import outilsJson from '../data/outils.json';
import contactJson from '../data/contact.json';

const facets = visibleFacets();
const N = facets.length;

// ── Labels en arc : calcul dynamique (zéro hardcode) ──────────────────────
const longestLen = Math.max(...facets.map(f => [...f.label].length));
const COND_RATIO = 0.42;
const CAP_RATIO  = 0.72;
const R_CAP      = 92;
const ARC_DEG    = 360 / N - 4;
const ARC_RAD    = ARC_DEG * Math.PI / 180;
const fontSize   = R_CAP / (longestLen * COND_RATIO / ARC_RAD + CAP_RATIO);
const rBaseline  = R_CAP - CAP_RATIO * fontSize;

function arcPath(angleDeg: number, r: number): string {
  const toRad = (d: number) => (d - 90) * Math.PI / 180;
  const half = ARC_DEG / 2;
  const s = toRad(angleDeg - half);
  const e = toRad(angleDeg + half);
  const upper = angleDeg <= 90 || angleDeg >= 270;
  const sx = r * Math.cos(s), sy = r * Math.sin(s);
  const ex = r * Math.cos(e), ey = r * Math.sin(e);
  return upper
    ? `M ${sx.toFixed(3)},${sy.toFixed(3)} A ${r},${r} 0 0 1 ${ex.toFixed(3)},${ey.toFixed(3)}`
    : `M ${ex.toFixed(3)},${ey.toFixed(3)} A ${r},${r} 0 0 0 ${sx.toFixed(3)},${sy.toFixed(3)}`;
}

// ── Données overlay par facette ───────────────────────────────────────────
const OVERLAY_GIGS_COUNT = 3;
const facetJsonMap: Record<string, Record<string, unknown>> = {
  son: sonJson as Record<string, unknown>,
  regie: regieJson as Record<string, unknown>,
  cours: coursJson as Record<string, unknown>,
  blog: blogJson as Record<string, unknown>,
  outils: outilsJson as Record<string, unknown>,
  contact: contactJson as Record<string, unknown>,
};

const allGigs = await getCollection('gigs', ({ data }) => !data.draft);
const today = new Date(); today.setHours(0, 0, 0, 0);
const upcomingGigs = allGigs
  .filter(g => g.data.date >= today)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, OVERLAY_GIGS_COUNT);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });

const STREAM_KEYS = ['soundcloud', 'mixcloud', 'spotify'] as const;

interface OverlayData {
  key: string;
  label: string;
  teaser: string;
  href: string;
  headline: string;
  streamLinks: { key: string; url: string; label: string }[];
  otherLinks:  { key: string; url: string }[];
  photos: string[];
  isSon: boolean;
}

const labelItems = facets.map((facet, i) => ({
  key:      facet.key,
  label:    facet.label,
  teaser:   facet.teaser,
  href:     facet.href,
  angleDeg: i * 360 / N,
  arcD:     arcPath(i * 360 / N, rBaseline),
}));

const overlayItems: OverlayData[] = labelItems.map(item => {
  const d = facetJsonMap[item.key] || {};
  const links = (d.links || {}) as Record<string, string>;
  const streamLinks = STREAM_KEYS
    .filter(k => links[k])
    .map(k => ({
      key: k,
      url: links[k],
      label: k === 'soundcloud' ? 'SoundCloud' : k === 'mixcloud' ? 'Mixcloud' : 'Spotify',
    }));
  const otherLinks = Object.entries(links)
    .filter(([k, v]) => !(STREAM_KEYS as readonly string[]).includes(k) && v)
    .map(([k, v]) => ({ key: k, url: v }));
  return {
    key:         item.key,
    label:       item.label,
    teaser:      item.teaser,
    href:        item.href,
    headline:    String(d.headline || item.label),
    streamLinks,
    otherLinks,
    photos:      Array.isArray(d.photos) ? (d.photos as string[]) : [],
    isSon:       item.key === 'son',
  };
});
---

<div class="scene" data-state="0" data-n-facets={N}>

  <div class="bg-stage" aria-hidden="true"></div>

  <div class="turntable">

    <div class="disk-indicator" aria-hidden="true"></div>

    <!-- Disque : fond CD sombre + labels textPath SVG -->
    <div class="disk">
      <svg
        class="disk-labels"
        viewBox="-100 -100 200 200"
        aria-hidden="true"
        focusable="false"
      >
        <defs>
          <!-- Masque CD : opacité croît du centre vers le bord -->
          <radialGradient id="tt-cd-grad" cx="50%" cy="50%" r="50%">
            <stop offset="25%" stop-color="black"/>
            <stop offset="100%" stop-color="white"/>
          </radialGradient>
          <mask id="tt-cd-mask">
            <rect x="-100" y="-100" width="200" height="200" fill="url(#tt-cd-grad)"/>
          </mask>

          <!-- Glow large (label actif) -->
          <filter id="tt-glow-l" x="-60%" y="-60%" width="220%" height="220%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="4"   result="b1"/>
            <feGaussianBlur in="SourceAlpha" stdDeviation="1.5" result="b2"/>
            <feMerge>
              <feMergeNode in="b1"/>
              <feMergeNode in="b2"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>

          <!-- Glow subtil (labels inactifs) -->
          <filter id="tt-glow-s" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="1.2" result="b"/>
            <feMerge>
              <feMergeNode in="b"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>

          <!-- Arc path par facette -->
          {labelItems.map(item => (
            <path id={`tt-arc-${item.key}`} d={item.arcD} fill="none"/>
          ))}
        </defs>

        {labelItems.map(item => (
          <text
            class={`disk-label disk-label--${item.key}`}
            font-family="Barlow Condensed, Arial Narrow, sans-serif"
            font-weight="800"
            font-size={fontSize.toFixed(2)}
            fill={`var(--facet-${item.key})`}
            stroke="var(--bg-app)"
            stroke-width="3"
            paint-order="stroke fill"
          >
            <textPath href={`#tt-arc-${item.key}`} startOffset="50%" text-anchor="middle">
              {item.label}
            </textPath>
          </text>
        ))}
      </svg>
    </div>

    <div class="disk-track"></div>

    <div class="disk-center" id="disk-center">
      <div class="center-s0">
        {siteData.logo_url ? (
          <svg viewBox="-22 -22 44 44" class="center-logo" aria-label={siteData.displayName}>
            <image href={siteData.logo_url} x="-22" y="-22" width="44" height="44" preserveAspectRatio="xMidYMid meet"/>
          </svg>
        ) : (
          <span class="center-name">{siteData.displayName}</span>
        )}
      </div>
      <div class="center-s1">
        <span class="preview-label" id="preview-label"></span>
        <span class="preview-teaser" id="preview-teaser"></span>
        <span class="preview-cta">ouvrir →</span>
      </div>
    </div>

    <!-- Zones de clic invisibles (une par facette) -->
    {labelItems.map(item => (
      <button
        class="pastille"
        data-facet={item.key}
        data-label={item.label}
        data-teaser={item.teaser}
        data-href={item.href}
        style="--x: 0px; --y: 0px"
        type="button"
        aria-label={item.label}
      />
    ))}

  </div>

  <!-- ── Overlays état 2 (un par facette) ───────────────────── -->
  {overlayItems.map(ov => (
    <div
      class="facet-overlay"
      id={`overlay-${ov.key}`}
      data-facet={ov.key}
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-label={`${ov.label} — aperçu`}
    >
      <button class="overlay-close" aria-label="Fermer">×</button>
      <div class="overlay-inner">
        <header class="overlay-hd">
          <span class={`overlay-chip chip--${ov.key}`}>{ov.label}</span>
          <h2 class="overlay-headline">{ov.headline}</h2>
          <p class="overlay-teaser">{ov.teaser}</p>
        </header>

        {ov.isSon && (
          <details class="overlay-block" open>
            <summary class="overlay-block-title">Gigs</summary>
            {upcomingGigs.length > 0 ? (
              <ul class="overlay-gig-list">
                {upcomingGigs.map(g => (
                  <li class="overlay-gig-row">
                    <time class="og-date">{fmtDate(g.data.date)}</time>
                    <span class="og-title">{g.data.title}</span>
                    <span class="og-format">{g.data.format}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="overlay-empty">Prochaines dates bientôt annoncées.</p>
            )}
            <a href="/son" class="overlay-link-more">Voir tous →</a>
          </details>
        )}

        {ov.streamLinks.length > 0 && (
          <details class="overlay-block">
            <summary class="overlay-block-title">Écoute</summary>
            <div class="overlay-stream-btns">
              {ov.streamLinks.map(sl => (
                <a href={sl.url} target="_blank" rel="noopener" class={`overlay-btn obtn--${ov.key}`}>
                  {sl.label}
                </a>
              ))}
            </div>
          </details>
        )}

        {ov.photos.length > 0 && (
          <details class="overlay-block">
            <summary class="overlay-block-title">Visuels</summary>
            <div class="overlay-photos">
              {ov.photos.map((url, pi) => (
                <button class="overlay-photo-btn" data-src={url} aria-label={`Photo ${pi + 1}`} type="button">
                  <img src={url} alt="" loading="lazy"/>
                </button>
              ))}
            </div>
          </details>
        )}

        {ov.otherLinks.length > 0 && (
          <details class="overlay-block">
            <summary class="overlay-block-title">Liens</summary>
            <ul class="overlay-links-list">
              {ov.otherLinks.map(ol => (
                <li><a href={ol.url} target="_blank" rel="noopener" class="overlay-link">{ol.key}</a></li>
              ))}
            </ul>
          </details>
        )}

        <a href={ov.href} class={`overlay-explore explore--${ov.key}`}>
          Explorer la page complète →
        </a>
      </div>
    </div>
  ))}

  <!-- Lightbox photos -->
  <div id="tt-lightbox" class="tt-lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="tt-lb-close" aria-label="Fermer">×</button>
    <img id="tt-lb-img" src="" alt="" class="tt-lb-img"/>
  </div>

</div>

<style>
  /* ─── Scène ──────────────────────────────────────────────────── */
  .scene {
    position: relative;
    width: 100%;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: none;
  }

  /* ─── Fond coloré (état 1) ───────────────────────────────────── */
  .bg-stage {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 80% at center,
      color-mix(in srgb, var(--stage-c, transparent) 10%, var(--bg-app)) 0%,
      var(--bg-app) 70%
    );
    opacity: 0;
    transition: opacity 0.5s ease, background 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }
  .scene[data-state="1"] .bg-stage { opacity: 1; }

  /* ─── Conteneur platine ──────────────────────────────────────── */
  .turntable {
    position: relative;
    width:  var(--disk-size, 560px);
    height: var(--disk-size, 560px);
    flex-shrink: 0;
    z-index: 1;
  }
  /* Contour coloré par facette active */
  .turntable::after {
    content: '';
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      transparent 60%,
      color-mix(in srgb, var(--active-facet-color, transparent) 10%, transparent) 100%
    );
    pointer-events: none;
    transition: background 0.7s ease;
    z-index: 0;
  }

  /* ─── Disque : fond CD sombre (oklch luminosité 0.25-0.35) ─── */
  .disk {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid var(--border);
    transform: rotate(var(--disk-rotation, 0deg));
    will-change: transform;
    background:
      radial-gradient(circle at center, var(--bg-elevated) 0%, transparent 62%),
      conic-gradient(
        from 0deg,
        oklch(0.28 0.22   0)   0deg,
        oklch(0.32 0.18  60)  60deg,
        oklch(0.30 0.17 120) 120deg,
        oklch(0.28 0.14 180) 180deg,
        oklch(0.28 0.18 240) 240deg,
        oklch(0.30 0.20 300) 300deg,
        oklch(0.28 0.22 360) 360deg
      );
    transition: box-shadow 0.4s ease;
  }
  .scene[data-state="1"] .disk {
    box-shadow: 0 0 80px -20px rgba(0, 0, 0, 0.7);
  }

  /* ─── SVG labels en arc ───────────────────────────────────────── */
  .disk-labels {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .disk-label {
    opacity: 0.65;
    filter: url('#tt-glow-s');
    transition: opacity 0.25s ease;
  }
  .disk-label.is-active {
    opacity: 1;
    filter: url('#tt-glow-l');
    mask: url('#tt-cd-mask');
  }

  /* ─── Anneau de track ────────────────────────────────────────── */
  .disk-track {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 500px;
    height: 500px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: transparent;
    border: none;
    pointer-events: none;
  }

  /* ─── Centre ─────────────────────────────────────────────────── */
  .disk-center {
    position: absolute;
    top: 50%;
    left: 50%;
    width:  var(--center-size, 180px);
    height: var(--center-size, 180px);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: var(--bg-app);
    border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    overflow: hidden;
    z-index: 2;
    transition:
      width  0.45s cubic-bezier(0.34, 1.4, 0.64, 1),
      height 0.45s cubic-bezier(0.34, 1.4, 0.64, 1),
      border-color 0.3s ease;
  }
  .scene[data-state="1"] .disk-center {
    width:  var(--center-size-open, 260px);
    height: var(--center-size-open, 260px);
    border-color: var(--preview-c, var(--border));
    cursor: pointer;
  }

  .center-s0,
  .center-s1 {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1.2rem;
    text-align: center;
    transition: opacity 0.2s ease;
  }
  .center-s0 { opacity: 1; }
  .center-s1 { opacity: 0; pointer-events: none; }
  .scene[data-state="1"] .center-s0 { opacity: 0; pointer-events: none; }
  .scene[data-state="1"] .center-s1 { opacity: 1; }

  .center-name {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .center-logo {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
  }
  .preview-label {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--preview-c, var(--text-primary));
    line-height: 1;
  }
  .preview-teaser {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.35;
  }
  .preview-cta {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--preview-c, var(--text-tertiary));
    opacity: 0.6;
    margin-top: 0.2rem;
  }

  /* ─── Indicateur fixe 12h ────────────────────────────────────── */
  .disk-indicator {
    position: absolute;
    top: calc(50% - var(--disk-size, 560px) / 2 - 14px);
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-top: 11px solid var(--text-secondary);
    pointer-events: none;
    z-index: 10;
    transition: border-top-color 0.3s ease;
  }

  /* ─── Zones de clic invisibles ───────────────────────────────── */
  .pastille {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 72px;
    height: 72px;
    transform: translate(calc(-50% + var(--x)), calc(-50% + var(--y)));
    border-radius: 50%;
    background: transparent;
    border: none;
    cursor: pointer;
    appearance: none;
    padding: 0;
  }
  .pastille:focus-visible {
    outline: 2px solid var(--border);
    outline-offset: 3px;
  }

  /* ─── Overlay état 2 ─────────────────────────────────────────── */
  .facet-overlay {
    position: fixed;
    inset: 0;
    background: var(--bg-app);
    clip-path: circle(0px at var(--ov-cx, 50vw) var(--ov-cy, 50vh));
    transition: clip-path 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 100;
    overflow-y: auto;
    pointer-events: none;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .facet-overlay.is-open {
    clip-path: circle(150vmax at var(--ov-cx, 50vw) var(--ov-cy, 50vh));
    pointer-events: auto;
  }

  .overlay-close {
    position: fixed;
    top: 1.2rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }
  .overlay-close:hover { background: var(--bg-surface); }

  .overlay-inner {
    width: 100%;
    max-width: 640px;
    padding: 5rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .overlay-hd {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }
  .overlay-chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    border: 1px solid currentColor;
  }
  .chip--son     { color: var(--facet-son); }
  .chip--regie   { color: var(--facet-regie); }
  .chip--cours   { color: var(--facet-cours); }
  .chip--blog    { color: var(--facet-blog); }
  .chip--outils  { color: var(--facet-outils); }
  .chip--contact { color: var(--facet-contact); }

  .overlay-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--text-primary);
  }
  .overlay-teaser {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 36ch;
    margin: 0;
    text-align: center;
  }

  /* ─── Blocs accordéon ───────────────────────────────────────── */
  .overlay-block {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .overlay-block-title {
    padding: 0.85rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    user-select: none;
    transition: color 0.15s ease;
  }
  .overlay-block-title::-webkit-details-marker { display: none; }
  .overlay-block-title::after {
    content: '▾';
    margin-left: auto;
    transition: transform 0.18s ease;
  }
  .overlay-block[open] .overlay-block-title::after { transform: rotate(180deg); }
  .overlay-block[open] .overlay-block-title { color: var(--text-secondary); }

  /* Gigs */
  .overlay-gig-list {
    list-style: none;
    margin: 0;
    padding: 0 1.2rem;
  }
  .overlay-gig-row {
    display: grid;
    grid-template-columns: 90px 1fr 48px;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-top: 1px solid var(--border);
    align-items: center;
  }
  .og-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-tertiary);
    white-space: nowrap;
  }
  .og-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .og-format {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--text-tertiary);
    text-align: right;
  }
  .overlay-empty {
    padding: 0.65rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin: 0;
  }
  .overlay-link-more {
    display: block;
    padding: 0.65rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--facet-son);
    text-decoration: none;
    border-top: 1px solid var(--border);
  }
  .overlay-link-more:hover { text-decoration: underline; }

  /* Streaming */
  .overlay-stream-btns {
    padding: 0.75rem 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
  .overlay-btn {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid currentColor;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .obtn--son     { color: var(--facet-son); }
  .obtn--regie   { color: var(--facet-regie); }
  .obtn--cours   { color: var(--facet-cours); }
  .obtn--blog    { color: var(--facet-blog); }
  .obtn--outils  { color: var(--facet-outils); }
  .obtn--contact { color: var(--facet-contact); }
  .overlay-btn:hover { background: color-mix(in srgb, currentColor 10%, transparent); }

  /* Photos */
  .overlay-photos {
    padding: 0.75rem 1.2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.5rem;
  }
  .overlay-photo-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 1;
  }
  .overlay-photo-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }
  .overlay-photo-btn:hover img { opacity: 0.8; }

  /* Liens */
  .overlay-links-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 1.2rem 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .overlay-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-secondary);
    text-decoration: none;
  }
  .overlay-link:hover { color: var(--text-primary); text-decoration: underline; }

  /* Bouton Explorer */
  .overlay-explore {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    border: 1px solid currentColor;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: background 0.2s ease;
    text-align: center;
  }
  .explore--son     { color: var(--facet-son); }
  .explore--regie   { color: var(--facet-regie); }
  .explore--cours   { color: var(--facet-cours); }
  .explore--blog    { color: var(--facet-blog); }
  .explore--outils  { color: var(--facet-outils); }
  .explore--contact { color: var(--facet-contact); }
  .overlay-explore:hover { background: color-mix(in srgb, currentColor 10%, transparent); }

  /* ─── Lightbox photos ────────────────────────────────────────── */
  .tt-lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .tt-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .tt-lb-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .tt-lb-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: none;
    color: white;
    font-size: 1.3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';

  let N_FACETS   = 6;
  let STEP       = 60;
  let BASE_ANGLES: number[] = [];
  const FRICTION    = 0.97;
  const VEL_THRESH  = 0.5;
  const BASE_STEP   = 2.5;   // deg/press initial
  const MAX_STEP    = 12;    // deg/press max

  let targetAngle  = 0;
  let currentAngle = 0;
  let velAngle     = 0;
  let RING_R_0     = 250;
  let RING_R_1     = 310;
  let targetRingR  = RING_R_0;
  let currentRingR = RING_R_0;
  let appState     = 0;
  let activeFacetIdx  = -1;
  let activeFacetHref = '';
  let rafId: number | null = null;
  let ctrl: AbortController | null = null;

  // Accélération clavier
  let keyHeldFrames = 0;
  let keyHeldDir    = 0; // +1 / -1 / 0

  document.addEventListener('astro:page-load', () => {
    if (rafId !== null) { cancelAnimationFrame(rafId); rafId = null; }
    ctrl?.abort();

    const scene = document.querySelector<HTMLElement>('.scene');
    if (!scene) return;

    N_FACETS = Number(scene.dataset.nFacets) || 6;
    STEP = 360 / N_FACETS;
    BASE_ANGLES = Array.from({ length: N_FACETS }, (_, i) => (i * STEP) - 90);

    ctrl = new AbortController();
    const sig = ctrl.signal;

    appState = 0;
    activeFacetIdx  = -1;
    activeFacetHref = '';
    targetAngle  = 0;
    currentAngle = 0;
    velAngle     = 0;
    scene.dataset.state = '0';

    function calcDiskSize(): number {
      return Math.min(
        document.documentElement.clientWidth  * 0.90,
        document.documentElement.clientHeight * 0.85,
        560
      );
    }

    function applyDiskSize(): void {
      const size = calcDiskSize();
      scene.style.setProperty('--disk-size',        size + 'px');
      scene.style.setProperty('--center-size',      Math.round(size * 0.29) + 'px');
      scene.style.setProperty('--center-size-open', Math.round(size * 0.42) + 'px');
      RING_R_0 = size / 2 * 0.80;
      RING_R_1 = size / 2 * 0.99;
      targetRingR  = appState === 1 ? RING_R_1 : RING_R_0;
      currentRingR = targetRingR;
    }

    applyDiskSize();

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => { applyDiskSize(); update(); }, 100);
    }, { signal: sig });

    const diskTrack     = document.querySelector<HTMLElement>('.disk-track')!;
    const centerEl      = document.querySelector<HTMLElement>('#disk-center')!;
    const indicator     = scene.querySelector<HTMLElement>('.disk-indicator')!;
    const bgStage       = document.querySelector<HTMLElement>('.bg-stage')!;
    const previewLabel  = document.querySelector<HTMLElement>('#preview-label')!;
    const previewTeaser = document.querySelector<HTMLElement>('#preview-teaser')!;
    const pastilles     = [...document.querySelectorAll<HTMLElement>('.pastille')];
    const labelEls      = [...document.querySelectorAll<Element>('.disk-label')];

    function update(): void {
      scene.style.setProperty('--disk-rotation', `${currentAngle.toFixed(2)}deg`);

      let activeIdx = 0;
      let minDist   = Infinity;

      for (let i = 0; i < N_FACETS; i++) {
        const deg = BASE_ANGLES[i] + currentAngle;
        const rad = (deg * Math.PI) / 180;
        pastilles[i].style.setProperty('--x', `${(Math.cos(rad) * currentRingR).toFixed(2)}px`);
        pastilles[i].style.setProperty('--y', `${(Math.sin(rad) * currentRingR).toFixed(2)}px`);

        const norm = ((deg + 90) % 360 + 360) % 360;
        const dist = Math.min(norm, 360 - norm);
        if (dist < minDist) { minDist = dist; activeIdx = i; }
      }

      for (let i = 0; i < N_FACETS; i++) {
        const active = i === activeIdx;
        pastilles[i].classList.toggle('is-active', active);
        labelEls[i]?.classList.toggle('is-active', active);
      }

      indicator.style.setProperty(
        'border-top-color',
        `var(--facet-${pastilles[activeIdx].dataset.facet})`
      );

      if (appState === 1 && activeIdx !== activeFacetIdx) {
        setState(1, activeIdx);
      }
      const d = `${(currentRingR * 2).toFixed(1)}px`;
      diskTrack.style.width = d;
      diskTrack.style.height = d;
    }

    function animate(): void {
      const rDiff = targetRingR - currentRingR;

      if (Math.abs(velAngle) > VEL_THRESH) {
        currentAngle += velAngle;
        velAngle     *= FRICTION;
        targetAngle   = currentAngle;
      } else {
        velAngle = 0;
        const aDiff = targetAngle - currentAngle;
        if (Math.abs(aDiff) < 0.02 && Math.abs(rDiff) < 0.05) {
          currentAngle = targetAngle;
          currentRingR = targetRingR;
          update();
          rafId = null;
          return;
        }
        currentAngle += aDiff * 0.12;
      }

      currentRingR += rDiff * 0.08;
      update();
      rafId = requestAnimationFrame(animate);
    }

    function schedule(): void {
      if (rafId === null) rafId = requestAnimationFrame(animate);
    }

    function getActiveIdx(): number {
      let idx = 0, minDist = Infinity;
      for (let i = 0; i < N_FACETS; i++) {
        const deg  = BASE_ANGLES[i] + currentAngle;
        const norm = ((deg + 90) % 360 + 360) % 360;
        const dist = Math.min(norm, 360 - norm);
        if (dist < minDist) { minDist = dist; idx = i; }
      }
      return idx;
    }

    function setState(newState: number, facetIdx = -1): void {
      appState = newState;
      scene.dataset.state = String(newState);

      if (newState === 1 && facetIdx >= 0) {
        activeFacetIdx  = facetIdx;
        activeFacetHref = pastilles[facetIdx].dataset.href!;
        const key    = pastilles[facetIdx].dataset.facet!;
        previewLabel.textContent  = pastilles[facetIdx].dataset.label!;
        previewTeaser.textContent = pastilles[facetIdx].dataset.teaser!;
        centerEl.style.setProperty('--preview-c', `var(--facet-${key})`);
        bgStage.style.setProperty('--stage-c',    `var(--facet-${key})`);
        document.documentElement.style.setProperty('--active-facet-color', `var(--facet-${key})`);
      } else if (newState === 0) {
        document.documentElement.style.setProperty('--active-facet-color', 'transparent');
      }

      targetRingR = newState === 1 ? RING_R_1 : RING_R_0;
      schedule();
    }

    function snapToFacet(idx: number): void {
      const desired = -90 - BASE_ANGLES[idx];
      const raw     = desired - targetAngle;
      const norm    = ((raw % 360) + 360) % 360;
      targetAngle  += (norm > 180 ? norm - 360 : norm);
      velAngle = 0;
      schedule();
    }

    function getTargetIdx(): number {
      let idx = 0, minDist = Infinity;
      for (let i = 0; i < N_FACETS; i++) {
        const deg  = BASE_ANGLES[i] + targetAngle;
        const norm = ((deg + 90) % 360 + 360) % 360;
        const dist = Math.min(norm, 360 - norm);
        if (dist < minDist) { minDist = dist; idx = i; }
      }
      return idx;
    }

    pastilles.forEach((el, idx) => {
      el.addEventListener('click', (e) => {
        e.stopPropagation(); snapToFacet(idx); setState(1, idx);
      }, { signal: sig });
    });

    // Overlay état 2
    const overlays = [...document.querySelectorAll<HTMLElement>('.facet-overlay')];
    const lightbox = document.getElementById('tt-lightbox')!;
    const lightboxImg = document.getElementById('tt-lb-img') as HTMLImageElement;

    function openOverlay(facetKey: string): void {
      const rect = centerEl.getBoundingClientRect();
      const cx = Math.round(rect.left + rect.width  / 2);
      const cy = Math.round(rect.top  + rect.height / 2);
      const ov = document.getElementById(`overlay-${facetKey}`);
      if (!ov) return;
      overlays.forEach(o => { o.classList.remove('is-open'); o.setAttribute('aria-hidden', 'true'); });
      ov.style.setProperty('--ov-cx', `${cx}px`);
      ov.style.setProperty('--ov-cy', `${cy}px`);
      ov.classList.add('is-open');
      ov.setAttribute('aria-hidden', 'false');
      appState = 2;
      scene.dataset.state = '2';
    }

    function closeOverlay(): void {
      overlays.forEach(o => { o.classList.remove('is-open'); o.setAttribute('aria-hidden', 'true'); });
      appState = 1;
      scene.dataset.state = '1';
    }

    centerEl.addEventListener('click', () => {
      if (appState === 1 && activeFacetIdx >= 0) {
        openOverlay(pastilles[activeFacetIdx].dataset.facet!);
      }
    }, { signal: sig });

    // Fermer overlay : × ou clic hors .overlay-inner ou Escape
    overlays.forEach(ov => {
      ov.querySelector('.overlay-close')?.addEventListener('click', () => closeOverlay(), { signal: sig });
      ov.addEventListener('click', (e) => {
        if (!(e.target as Element).closest('.overlay-inner') &&
            !(e.target as Element).closest('.overlay-close')) {
          closeOverlay();
        }
      }, { signal: sig });
    });

    // Lightbox photos
    document.querySelectorAll<HTMLElement>('.overlay-photo-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const src = btn.dataset.src || '';
        if (!src) return;
        lightboxImg.src = src;
        lightbox.classList.add('is-open');
        lightbox.setAttribute('aria-hidden', 'false');
      }, { signal: sig });
    });
    lightbox.querySelector('.tt-lb-close')?.addEventListener('click', () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
    }, { signal: sig });
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        lightbox.classList.remove('is-open');
        lightbox.setAttribute('aria-hidden', 'true');
      }
    }, { signal: sig });

    // Accélération clavier progressive
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        keyHeldDir = 0; keyHeldFrames = 0;
        if (appState === 2) closeOverlay();
        else setState(0);
        return;
      }
      if (e.key === 'Enter')  { if (appState === 1 && activeFacetHref) navigate(activeFacetHref); return; }

      const isRight = e.key === 'ArrowRight' || e.key === 'ArrowDown';
      const isLeft  = e.key === 'ArrowLeft'  || e.key === 'ArrowUp';
      if (!isRight && !isLeft) return;
      e.preventDefault();

      const dir = isRight ? 1 : -1;
      if (dir !== keyHeldDir) { keyHeldDir = dir; keyHeldFrames = 0; }
      keyHeldFrames++;

      const step  = Math.min(BASE_STEP + keyHeldFrames * 0.15, MAX_STEP);
      velAngle = dir * step * 0.35;
      const idx = (getTargetIdx() + dir + N_FACETS) % N_FACETS;
      snapToFacet(idx); setState(1, idx);
    }, { signal: sig });

    window.addEventListener('keyup', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown' ||
          e.key === 'ArrowLeft'  || e.key === 'ArrowUp') {
        keyHeldDir = 0; keyHeldFrames = 0;
      }
    }, { signal: sig });

    scene.addEventListener('click', (e) => {
      if (appState > 0 && !(e.target as Element).closest('.turntable')) setState(0);
    }, { signal: sig });

    scene.addEventListener('wheel', (e) => {
      e.preventDefault();
      velAngle = 0;
      const raw = (e as WheelEvent).deltaY;
      const capped = Math.sign(raw) * Math.min(Math.abs(raw), 80);
      targetAngle -= capped * 0.25;
      schedule();
    }, { passive: false, signal: sig } as AddEventListenerOptions);

    let mouseDown = false;
    let mouseDragStartAngle = 0;
    let mouseDragStartRotation = 0;
    let mouseDragDist = 0;
    let mouseDragStartX = 0;
    let mouseDragStartY = 0;
    let mouseSamples: Array<{ angle: number; t: number }> = [];

    scene.addEventListener('mousedown', (e) => {
      if (e.button !== 0) return;
      e.preventDefault();
      mouseDown = true;
      mouseDragStartX = e.clientX; mouseDragStartY = e.clientY; mouseDragDist = 0;
      const rect = scene.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      mouseDragStartAngle = Math.atan2(e.clientY - cy, e.clientX - cx) * (180 / Math.PI);
      mouseDragStartRotation = currentAngle;
      velAngle = 0; mouseSamples = [];
    }, { signal: sig });

    window.addEventListener('mousemove', (e) => {
      if (!mouseDown) return;
      mouseDragDist = Math.hypot(e.clientX - mouseDragStartX, e.clientY - mouseDragStartY);
      const rect = scene.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const angle = Math.atan2(e.clientY - cy, e.clientX - cx) * (180 / Math.PI);
      currentAngle = mouseDragStartRotation + (angle - mouseDragStartAngle);
      targetAngle = currentAngle;
      const now = performance.now();
      mouseSamples.push({ angle: currentAngle, t: now });
      if (mouseSamples.length > 4) mouseSamples.shift();
      update();
    }, { signal: sig });

    window.addEventListener('mouseup', (e) => {
      if (!mouseDown) return;
      mouseDown = false;
      if (mouseSamples.length >= 2) {
        const first = mouseSamples[0];
        const last  = mouseSamples[mouseSamples.length - 1];
        const dt = last.t - first.t;
        if (dt > 0) velAngle = (last.angle - first.angle) / dt * 16;
      }
      if (mouseDragDist < 5 && !(e.target as Element).closest('.disk-center')) setState(0);
      schedule();
    }, { signal: sig });

    const VEL_SAMPLES = 4;
    let touchLastDeg = 0;
    let touchLastMs  = 0;
    let velBuf: number[] = [];
    let touchStartX = 0;
    let touchStartY = 0;

    function fingerAngle(t: Touch): number {
      const cx = window.innerWidth  / 2;
      const cy = window.innerHeight / 2;
      return Math.atan2(t.clientY - cy, t.clientX - cx) * (180 / Math.PI);
    }

    function wrapDelta(d: number): number {
      while (d >  180) d -= 360;
      while (d < -180) d += 360;
      return d;
    }

    scene.addEventListener('touchstart', (e) => {
      const te = e as TouchEvent;
      if (te.touches.length !== 1) return;
      touchLastDeg = fingerAngle(te.touches[0]);
      touchLastMs  = performance.now();
      touchStartX  = te.touches[0].clientX;
      touchStartY  = te.touches[0].clientY;
      velAngle = 0; velBuf = [];
      targetAngle = currentAngle;
    }, { passive: true, signal: sig } as AddEventListenerOptions);

    scene.addEventListener('touchmove', (e) => {
      const te = e as TouchEvent;
      if (te.touches.length !== 1) return;
      e.preventDefault();
      const newDeg = fingerAngle(te.touches[0]);
      const now    = performance.now();
      const dt     = Math.max(now - touchLastMs, 1);
      const delta  = wrapDelta(newDeg - touchLastDeg);
      currentAngle += delta;
      targetAngle   = currentAngle;
      velBuf.push(delta / dt * (1000 / 60));
      if (velBuf.length > VEL_SAMPLES) velBuf.shift();
      touchLastDeg = newDeg;
      touchLastMs  = now;
      schedule();
    }, { passive: false, signal: sig } as AddEventListenerOptions);

    scene.addEventListener('touchend', (e) => {
      if (velBuf.length > 0)
        velAngle = velBuf.reduce((a, b) => a + b, 0) / velBuf.length;
      velBuf = [];
      const te = e as TouchEvent;
      const touch = te.changedTouches[0];
      if (touch) {
        const dist = Math.hypot(touch.clientX - touchStartX, touch.clientY - touchStartY);
        if (dist < 5 && !(e.target as Element).closest('.disk-center')) setState(0);
      }
      schedule();
    }, { passive: true, signal: sig } as AddEventListenerOptions);

    update();
  });
</script>
