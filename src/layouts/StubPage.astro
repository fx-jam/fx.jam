---
/**
 * StubPage — gabarit temporaire pour les facettes en chantier.
 *
 * Affiche une page minimale propre, en attendant le contenu réel.
 * Utilise les tokens design : la couleur de la facette habille le titre
 * et le retour à l'accueil.
 *
 * Sera remplacé par les vraies pages de facette au fil de la refonte.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFacet, type FacetKey } from '../data/facets.ts';

export interface Props {
  facet: FacetKey;
  title?: string;
}

const { facet, title } = Astro.props;
const f = getFacet(facet);
const pageTitle = title ?? `${f?.label ?? facet} — hamcat.live`;
---

<BaseLayout title={pageTitle} description={f?.teaser}>
  <main class="stub">
    <span class="label">{f?.label}</span>
    <h1>En construction</h1>
    <p class="teaser">{f?.teaser}</p>
    <p class="note">Cette page sera bientôt développée. En attendant, retour à l'accueil.</p>
    <a class="home" href="/">← Accueil</a>
  </main>
</BaseLayout>

<style define:vars={{ color: `var(--facet-${Astro.props.facet})` }}>
  .stub {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    gap: 0.6rem;
  }

  .label {
    color: var(--color);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--text-primary);
  }

  .teaser {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 38ch;
    margin: 0.5rem 0 0;
  }

  .note {
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin: 1.5rem 0 2rem;
  }

  .home {
    color: var(--color);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--color);
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .home:hover {
    background: color-mix(in srgb, var(--color) 15%, transparent);
  }
</style>
