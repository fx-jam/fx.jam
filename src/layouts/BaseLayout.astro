---
import { ViewTransitions } from 'astro:transitions';
import { visibleFacets } from '../data/facets';
import siteData from '../data/site.json';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const facetHrefs = visibleFacets().map(f => f.href);
---
<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <ViewTransitions />

  <style is:global>
    /* ============================================================
       DESIGN TOKENS — hamcat.live
       Source de vérité unique pour palette + typographie.
       Modifier ici se répercute partout dans le site.
       ============================================================ */
    :root {
      /* Couleurs des facettes (arc-en-ciel saturé, ordre = spectre) */
      --facet-son:     oklch(0.65 0.22 25);   /* rouge-orange   ~0 deg spectre  */
      --facet-regie:   oklch(0.75 0.18 80);   /* jaune-or       ~60 deg spectre */
      --facet-cours:   oklch(0.70 0.17 145);  /* vert           ~120 deg spectre */
      --facet-blog:    oklch(0.72 0.14 195);  /* cyan           ~180 deg spectre */
      --facet-outils:  oklch(0.65 0.18 260);  /* bleu           ~240 deg spectre */
      --facet-contact: oklch(0.68 0.20 320);  /* violet-rose    ~300 deg spectre */

      /* Neutres (dark theme) */
      --bg-app: #0b0b10;       /* fond global */
      --bg-surface: #15151c;   /* surfaces / cartes */
      --bg-elevated: #1f1f28;  /* surfaces élevées */
      --border: #2a2a33;       /* bordures discrètes */

      /* Texte */
      --text-primary: #f0f0f5;
      --text-secondary: #9a9aac;
      --text-tertiary: #55555f;

      /* Typographie */
      --font-display: 'Barlow Condensed', system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    }

    /* ============================================================
       RESET & LAYOUT GLOBAL
       Viewport fixe, pas de scroll de page entière.
       Le scroll vit à l'intérieur des composants.
       ============================================================ */
    html, body {
      height: 100%;
      overflow: hidden;
      margin: 0;
      padding: 0;
      background-color: var(--bg-app);
      color: var(--text-primary);
      font-family: var(--font-display);
      -webkit-font-smoothing: antialiased;
    }

    body {
      position: fixed;
      width: 100%;
      overscroll-behavior: none;
    }

    /* Fond de page (image avec opacité réduite) */
    .bg-fond {
      position: fixed;
      inset: 0;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.10;
      pointer-events: none;
      z-index: 0;
    }

    /* Scrollbar discrète, neutre */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg-surface); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-tertiary); }

    /* ============================================================
       VIEW TRANSITIONS
       Iris depuis le centre (130 px = rayon du disque en état 1).
       Forward : iris s'ouvre. Back : iris se referme.
       ============================================================ */
    @keyframes vt-iris-in {
      from { clip-path: circle(130px at 50% 50%); }
      to   { clip-path: circle(150% at 50% 50%); }
    }
    @keyframes vt-iris-out {
      from { clip-path: circle(150% at 50% 50%); }
      to   { clip-path: circle(130px at 50% 50%); }
    }
    @keyframes vt-fade-out { to   { opacity: 0; } }
    @keyframes vt-fade-in  { from { opacity: 0; } }

    /* Aller : nouveau contenu émerge de l'iris, ancien s'efface */
    ::view-transition-old(root) {
      animation: 220ms ease-in both vt-fade-out;
    }
    ::view-transition-new(root) {
      animation: 460ms cubic-bezier(0.25, 0.46, 0.45, 0.94) both vt-iris-in;
    }

    /* Retour : iris se referme, ancien reparaît */
    html[data-astro-transition="back"] ::view-transition-old(root) {
      animation: 460ms cubic-bezier(0.25, 0.46, 0.45, 0.94) both vt-iris-out;
    }
    html[data-astro-transition="back"] ::view-transition-new(root) {
      animation: 220ms ease-out both vt-fade-in;
    }

    /* Respecte la préférence de réduction de mouvement */
    @media (prefers-reduced-motion: reduce) {
      ::view-transition-old(root),
      ::view-transition-new(root) { animation: none; }
    }
  </style>

  <script>
    // ── Navigation clavier inter-facettes ────────────────────
    // ← → : cycle entre facettes (toutes pages sauf accueil)
    // Échap : retour accueil
    // ↑ ↓  : libre (scroll de page)
    import { navigate } from 'astro:transitions/client';

    let ctrl: AbortController | null = null;

    document.addEventListener('astro:page-load', () => {
      ctrl?.abort();

      if (window.location.pathname === '/') return; // turntable gère lui-même

      const el = document.getElementById('facet-nav');
      if (!el) return;
      const hrefs: string[] = JSON.parse(el.dataset.hrefs ?? '[]');

      const path = window.location.pathname;
      const idx  = hrefs.findIndex(h => path === h || path.startsWith(h + '/'));
      if (idx === -1) return; // page hors-facette (/404, etc.)

      const prevHref = hrefs[(idx - 1 + hrefs.length) % hrefs.length];
      const nextHref = hrefs[(idx + 1) % hrefs.length];

      ctrl = new AbortController();
      window.addEventListener('keydown', (e) => {
        if ((e.target as Element).closest('input, textarea, [contenteditable]')) return;
        if      (e.key === 'ArrowLeft')  { e.preventDefault(); navigate(prevHref); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); navigate(nextHref); }
        else if (e.key === 'Escape')     { navigate('/'); }
      }, { signal: ctrl.signal });
    });
  </script>
</head>
<body>
  <!-- Fond de page (si fond_url rempli dans site.json) -->
  {siteData.fond_url && (
    <div
      class="bg-fond"
      style={`background-image: url('${siteData.fond_url}')`}
      aria-hidden="true"
    ></div>
  )}
  <!-- Hrefs des facettes pour la navigation clavier globale -->
  <div id="facet-nav" data-hrefs={JSON.stringify(facetHrefs)} style="display:none" aria-hidden="true"></div>
  <slot />
</body>
</html>
