---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Modal from '../components/Modal.astro';
---

<BaseLayout title="fx.jam" description="DJ, producteur et ingénieur son basé dans les Alpes">
  <Header />
  
  <main class="fixed inset-0 top-0 overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900">
    <div class="h-full flex items-center justify-center p-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full max-w-5xl">
        <!-- DJ Sets -->
        <button 
          data-modal="dj"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-primary-500/50 group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white mb-1 group-hover:text-primary-400 transition-colors text-center">
            DJ Sets
          </h2>
          <p class="text-gray-400 text-sm text-center">
            Psytrance • Festivals • Booking
          </p>
        </button>

        <!-- Production -->
        <button 
          data-modal="music"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-accent-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white mb-1 group-hover:text-accent-400 transition-colors text-center">
            Production
          </h2>
          <p class="text-gray-400 text-sm text-center">
            EP Mars 2025
          </p>
        </button>

        <!-- Sound Engineer -->
        <button 
          data-modal="sound"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-primary-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white mb-1 group-hover:text-primary-400 transition-colors text-center">
            Ingénieur Son
          </h2>
          <p class="text-gray-400 text-sm text-center">
            X32/M32 • FOH
          </p>
        </button>

        <!-- Tools -->
        <button 
          data-modal="tools"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-accent-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white group-hover:text-accent-400 transition-colors text-center">
            Tools
          </h2>
        </button>

        <!-- Blog -->
        <button 
          data-modal="blog"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-primary-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white group-hover:text-primary-400 transition-colors text-center">
            Blog
          </h2>
        </button>

        <!-- Playlists -->
        <button 
          data-modal="playlists"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-accent-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white group-hover:text-accent-400 transition-colors text-center">
            Playlists
          </h2>
        </button>

        <!-- Liens -->
        <button 
          data-modal="liens"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-primary-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white group-hover:text-primary-400 transition-colors text-center">
            Liens
          </h2>
        </button>

        <!-- Contact -->
        <a 
          href="mailto:contact@hamcat.live"
          class="aspect-square bg-gray-800/50 backdrop-blur-md rounded-xl p-4 hover:bg-gray-800/70 transition-all border border-gray-700/50 hover:border-primary-500/50 text-left group flex flex-col justify-center items-center"
        >
          <h2 class="text-xl font-bold font-['Space_Grotesk'] text-white group-hover:text-primary-400 transition-colors text-center">
            Contact
          </h2>
        </a>

      </div>
    </div>
  </main>

  <!-- Modal DJ -->
  <Modal id="dj">
    <article class="text-white p-8 md:p-10 max-h-[85vh] overflow-y-auto">
      
