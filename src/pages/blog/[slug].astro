---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  if (posts.length === 0) return [];
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<BaseLayout title={`${post.data.title} — Blog hamcat.live`} description={post.data.description}>
  <article class="post">
    <a class="back" href="/blog">← Tous les articles</a>

    <header class="hd">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="lead">{post.data.description}</p>}
      {post.data.tags.length > 0 && (
        <ul class="tags">
          {post.data.tags.map((t) => <li>{t}</li>)}
        </ul>
      )}
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    min-height: 100vh;
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .back {
    color: var(--facet-blog);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    align-self: flex-start;
  }
  .back:hover { opacity: 0.7; }
  .hd { display: flex; flex-direction: column; gap: 0.6rem; }
  time {
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--text-primary);
  }
  .lead {
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.5;
    margin: 0;
  }
  .tags { list-style: none; padding: 0; margin: 0.5rem 0 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-tertiary);
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .body {
    color: var(--text-primary);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .body :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.8rem;
    margin: 2.5rem 0 1rem;
    color: var(--text-primary);
  }
  .body :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    margin: 2rem 0 0.8rem;
    color: var(--text-primary);
  }
  .body :global(p) { margin: 0 0 1.2rem; }
  .body :global(a) { color: var(--facet-blog); }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
  .body :global(pre) {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
  }
  .body :global(pre code) { background: transparent; padding: 0; }
  .body :global(blockquote) {
    border-left: 3px solid var(--facet-blog);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }
</style>
